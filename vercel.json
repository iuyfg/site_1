{
  "version": 2,
  "buildCommand": "python manage.py migrate && python create_admin.py",
  "builds": [
    {
      "src": "korochki/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "korochki/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "korochki/wsgi.py"
    }
  ]
}